FROM maven:3.9-eclipse-temurin-21-alpine AS build
WORKDIR /workspace
COPY pom.xml .
COPY kyc-engine/pom.xml kyc-engine/
RUN mvn -pl kyc-engine -am dependency:go-offline -q
COPY kyc-engine/src kyc-engine/src
RUN mvn -pl kyc-engine -am package -DskipTests -q

FROM eclipse-temurin:21-jre-alpine
WORKDIR /app
COPY --from=build /workspace/kyc-engine/target/kyc-engine-1.0.0-SNAPSHOT.jar app.jar
EXPOSE 8083
ENTRYPOINT ["java", "-jar", "app.jar"]
